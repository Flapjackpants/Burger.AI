# Agent Configuration
AGENT_PORT=5002

# Agent Provider (openai or anthropic)
AGENT_PROVIDER=openai

# API Keys for the Agent being tested
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Stripe Key if testing payment capabilities
STRIPE_SECRET_KEY=sk_test_...

# Guardrails (Optional, usually set by backend)
# GUARDRAILS=[...]
