# Backend Configuration
PORT=5001

# LLM API Keys (Can be the same key for all if usage limits allow)
# Key for generating red-team attacks
OPENAI_API_KEY_REDTEAM=sk-...
# Key for evaluating agent responses
OPENAI_API_KEY_EVAL=sk-...
# Key for generating guardrails
OPENAI_API_KEY_GUARD=sk-...

# Evaluation & Red Teaming Models (Optional overrides)
EVALUATOR_LLM_MODEL=gpt-4o-mini
RED_TEAM_LLM_MODEL=gpt-4o-mini

# Evaluator Limits (Optional)
EVALUATOR_MAX_PROMPT_CHARS=2500
EVALUATOR_MAX_RESPONSE_CHARS=3000
